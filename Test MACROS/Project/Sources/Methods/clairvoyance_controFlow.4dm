// var $counter : Integer

var $counter; $start; $step; $stop : Integer
For ($counter; $start; $stop; $step)  // Comment
	
	var $condition : Boolean
	var $o : Object
	While ($condition)  // $o:={}
		
		// Comment
		var $count : Real
		var $i : Integer
		$count+=$i
		
	End while 
End for 

$o.count:=1
var $continue : Boolean
var $key : Text
For each ($key; $o) While ($continue)
	
	//
	
End for each 

Repeat 
	
	//
	
	var $end : Boolean
Until ($end)

