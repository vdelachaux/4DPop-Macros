//%attributes = {}
/* Clairvoyance test — LITERAL syntax & operators (no syntax file needed).
Each variable is assigned on its own line → declaration merged with the assignment. */

$n:=42  // Integer
$r:=3.14  // Real
$s:="hello"  // Text
$b:=True:C214  // Boolean
$obj:={name: "x"}  // Object
$col:=[1; 2; 3]  // Collection
$d:=!2024-12-25!  // Date
$h:=?12:30:00?  // Time
$p:=->$s  // Pointer
$pi2:=Pi:K30:1

$maxlong:=MAXLONG:K35:2

/*
var $n : Integer:=42  // Integer
var $r : Real:=3.14  // Real
var $s : Text:="hello"  // Text
var $b : Boolean:=True  // Boolean
var $obj : Object:={name: "x"}  // Object
var $col : Collection:=[1; 2; 3]  // Collection
var $d : Date:=!2024-12-25!  // Date
var $h : Time:=?12:30:00?  // Time
var $p : Pointer:=->$s  // Pointer
var $pi2 : Real:=Pi

var $maxlong : Integer:=MAXLONG
*/

